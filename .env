DOMAIN=ktown.gg
BASE_DIR=/opt/docker/infrastack

# Traefik / SSL
ACME_EMAIL=admin@ktown.gg
DESEC_TOKEN=***changeme***

# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=***changeme***

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@ktown.gg
PGADMIN_DEFAULT_PASSWORD=***changeme***

# Authentik Configuration
AUTHENTIK_SECRET_KEY=***changeme***
AUTHENTIK_ALLOWED_HOSTS=auth.ktown.gg
AUTHENTIK_LOG_LEVEL=info
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_POSTGRESQL__PASSWORD_FROM_ENV=true
AUTHENTIK_REDIS__HOST_FROM_ENV=true
AUTHENTIK_ALLOWED_PROXY_HOSTS=traefik

# NetBird VPN Configuration
# NETBIRD_AUTH_AUTHORITY: full OIDC issuer URL (Authentik: https://auth.ktown.gg/application/o/netbird/)
NETBIRD_AUTH_AUTHORITY=***changeme***
# NETBIRD_AUTH_CLIENT_ID: OAuth2 client ID created in Authentik for NetBird
NETBIRD_AUTH_CLIENT_ID=***changeme***
# NETBIRD_TURN_EXTERNAL_IP: the public IPv4 of your Hetzner VPS
NETBIRD_TURN_EXTERNAL_IP=***changeme***
NETBIRD_TURN_USER=netbird
NETBIRD_TURN_PASSWORD=***changeme***
