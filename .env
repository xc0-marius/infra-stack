DOMAIN=ktown.gg
BASE_DIR=/opt/infra -stack

# Traefik / SSL
ACME_EMAIL=admin@ktown.gg
DESEC_TOKEN=***changeme***

# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=***changeme***

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@ktown.gg
PGADMIN_DEFAULT_PASSWORD=***changeme***

# Authentik Configuration
AUTHENTIK_SECRET_KEY=***changeme***
AUTHENTIK_ALLOWED_HOSTS=auth.ktown.gg
AUTHENTIK_LOG_LEVEL=info
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_POSTGRESQL__PASSWORD_FROM_ENV=true
AUTHENTIK_REDIS__HOST_FROM_ENV=true
AUTHENTIK_ALLOWED_PROXY_HOSTS=traefik
#
